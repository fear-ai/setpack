#!/usr/bin/env bash
set -euo pipefail

SETPACK_TAG="setpack-openclaw"
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
. "$SCRIPT_DIR/lib/setpack-openclaw.sh"

usage() {
  cat <<'EOF'
usage: scripts/setpack-openclaw <command>

commands:
  prepare   ensure openclaw layout
  install   install the pinned openclaw bundle
  wrap      rewrite the pack-local openclaw wrapper
  configure create pack-local openclaw config, seed workspace docs, and wire cred/state links
  import-claude-auth [-f]  import Claude CLI native credentials into pack-local cred storage
  validate  validate the openclaw bundle, wrapper, and config
EOF
}

main() {
  local force
  setpack_pack_load_context
  setpack_openclaw_load_context
  case "${1:-}" in
    prepare)
      setpack_openclaw_ensure_layout
      ;;
    install)
      setpack_openclaw_install_bundle
      ;;
    wrap)
      setpack_openclaw_ensure_layout
      setpack_openclaw_write_wrapper
      ;;
    configure)
      setpack_openclaw_ensure_layout
      setpack_openclaw_configure
      ;;
    import-claude-auth)
      shift
      force=0
      case "${1:-}" in
        -f|--force)
          force=1
          shift
          ;;
      esac
      [ "$#" -eq 0 ] || setpack_die "usage: scripts/setpack-openclaw import-claude-auth [-f]"
      setpack_openclaw_ensure_layout
      setpack_openclaw_import_claude_auth "$force"
      ;;
    validate)
      setpack_openclaw_validate
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      usage
      exit 2
      ;;
  esac
}

main "$@"
