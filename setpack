#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
SCRIPTS_DIR="$SCRIPT_DIR/scripts"

. "$SCRIPTS_DIR/lib/setpack-pack.sh"

REPACK_AFTER="no"

show_cred_plan() {
  cat <<'EOF'
Credential setup modes:

1. Full automated
   - read from a declared pack cred source
   - materialize directly into the target pack
   - suitable for env files, copied JSON credentials, and pack-owned exports

2. Hybrid
   - automate bundle/config/state
   - pause for provider-native auth or token paste
   - then validate and capture resulting auth/state in the target pack

3. Manual
   - operator performs the package-native setup by hand
   - setpack only records status and validates placement afterward

Credential sources to support:

- another pack
  copy or transform selected cred material from one pack to another
- cred store
  a dedicated file-backed cred directory or encrypted export
- system config
  import from existing host config only when explicitly requested

Recommended rule:

- automate config and bundle steps first
- keep cred moves explicit and selective
- record the chosen mode in status.toml per subsystem and integration
EOF
}

usage() {
  cat <<'EOF'
usage: setpack [--repack] <command>

top-level commands:
  apply            prepare the pack substrate, install openclaw and gog, and refresh wrappers and combination status
  validate         validate openclaw, gog, and the openclaw-gog combination
  wrap             rewrite pack env plus openclaw and gog wrappers
  install-openclaw prepare openclaw layout and install the pinned openclaw bundle
  install-gog      prepare gog layout, duplicate the current gog binary, and rewrite the gog wrapper
  install-gws      prepare gws layout, record the current gws entrypoint, and rewrite the gws wrapper
  import           import conf|cred|state|workspace for a component from another pack (-f to replace non-empty destination)
  status           print status.toml
  cred-plan        print credential setup approaches

layered commands:
  pack <command>           generic set/pack substrate operations
  openclaw <command>       openclaw-specific operations
  gog <command>            gog-specific operations
  gws <command>            gws-specific operations
  openclaw-gog <command>   combination-layer operations

options:
  --repack         call repack -f <root> <set> <pack> after successful mutating commands
EOF
}

dispatch_script() {
  local script_name="$1"
  shift
  "$SCRIPTS_DIR/$script_name" "$@"
}

find_repack_script() {
  if [ -n "${SETPACK_REPACK_SCRIPT:-}" ]; then
    [ -x "$SETPACK_REPACK_SCRIPT" ] || setpack_die "SETPACK_REPACK_SCRIPT is not executable: $SETPACK_REPACK_SCRIPT"
    printf '%s\n' "$SETPACK_REPACK_SCRIPT"
    return 0
  fi
  if [ -x "$SCRIPT_DIR/repack" ]; then
    printf '%s\n' "$SCRIPT_DIR/repack"
    return 0
  fi
  return 1
}

maybe_repack() {
  local repack_script
  [ "$REPACK_AFTER" = "yes" ] || return 0
  setpack_pack_load_context
  repack_script="$(find_repack_script)" || setpack_die "--repack requested but repack was not found; set SETPACK_REPACK_SCRIPT"
  setpack_log "run repack via $repack_script"
  "$repack_script" -f "$SETPACK_ROOT" "$SET_NAME" "$PACK_NAME"
}

main() {
  local args command

  args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --repack)
        REPACK_AFTER="yes"
        ;;
      *)
        args+=("$1")
        ;;
    esac
    shift
  done
  set -- "${args[@]}"
  command="${1:-}"

  case "$command" in
    apply)
      dispatch_script setpack-pack prepare
      dispatch_script setpack-openclaw prepare
      dispatch_script setpack-openclaw install
      dispatch_script setpack-openclaw wrap
      dispatch_script setpack-gog prepare
      dispatch_script setpack-gog install
      dispatch_script setpack-gog wrap
      dispatch_script setpack-openclaw-gog refresh-status
      maybe_repack
      ;;
    validate)
      local rc=0
      if ! dispatch_script setpack-openclaw validate; then
        rc=1
      fi
      if ! dispatch_script setpack-gog validate; then
        rc=1
      fi
      if ! dispatch_script setpack-openclaw-gog validate; then
        rc=1
      fi
      return "$rc"
      ;;
    wrap)
      dispatch_script setpack-pack prepare
      dispatch_script setpack-openclaw prepare
      dispatch_script setpack-openclaw wrap
      dispatch_script setpack-gog prepare
      dispatch_script setpack-gog wrap
      dispatch_script setpack-openclaw-gog refresh-status
      maybe_repack
      ;;
    install-openclaw)
      dispatch_script setpack-openclaw prepare
      dispatch_script setpack-openclaw install
      dispatch_script setpack-openclaw-gog refresh-status
      maybe_repack
      ;;
    install-gog)
      dispatch_script setpack-gog prepare
      dispatch_script setpack-gog install
      dispatch_script setpack-gog wrap
      dispatch_script setpack-openclaw-gog refresh-status
      maybe_repack
      ;;
    install-gws)
      dispatch_script setpack-gws prepare
      dispatch_script setpack-gws install
      dispatch_script setpack-gws wrap
      maybe_repack
      ;;
    import)
      shift
      dispatch_script setpack-pack import "$@"
      dispatch_script setpack-openclaw-gog refresh-status
      maybe_repack
      ;;
    status)
      dispatch_script setpack-pack status
      ;;
    cred-plan)
      show_cred_plan
      ;;
    pack|openclaw|gog|gws|openclaw-gog)
      shift
      dispatch_script "setpack-$command" "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      usage
      exit 2
      ;;
  esac
}

main "$@"
